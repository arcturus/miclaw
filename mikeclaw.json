{
  "defaultAgent": "assistant",
  "defaultModel": "sonnet",
  "soulDir": "./soul",
  "skillsDir": "./skills",
  "memoryDir": "./memory",
  "sessionsDir": "./sessions",
  "journalDays": 3,
  "promptMode": "append",
  "mcpConfig": null,
  "permissionMode": "default",
  "maxConcurrentProcesses": 5,
  "maxQueueDepth": 20,
  "maxTurnsPerSession": 20,
  "sessionTtlDays": 30,
  "channels": {
    "cli": {
      "enabled": true,
      "prompt": "you> "
    },
    "web": {
      "enabled": true,
      "port": 3456,
      "host": "127.0.0.1",
      "auth": {
        "type": "none"
      }
    }
  },
  "cron": {
    "enabled": true,
    "jobsFile": "./cron/jobs.json"
  },
  "learning": {
    "enabled": true,
    "model": "haiku",
    "afterEveryTurn": false,
    "consolidationCron": "0 2 * * *",
    "maxLearningEntries": 200
  }
}
