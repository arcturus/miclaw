[
  {
    "id": "daily-summary",
    "schedule": "0 9 * * *",
    "agent": "assistant",
    "message": "Review my recent journal entries and provide a brief morning summary of key items.",
    "enabled": true,
    "outputMode": "broadcast",
    "broadcastTarget": { "channel": "web", "userId": "*" }
  },
  {
    "id": "heartbeat",
    "schedule": "*/30 * * * *",
    "agent": "assistant",
    "message": "{{HEARTBEAT}}",
    "enabled": true,
    "outputMode": "journal"
  }
]
