{
  "name": "miclaw",
  "version": "0.1.0",
  "description": "Minimal agentic bot framework proxying to Claude Code",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "miclaw": "./bin/miclaw.mjs"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "setup": "tsx src/setup.ts",
    "setup:show": "tsx src/setup.ts show",
    "test": "vitest run"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.67.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.14",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
